# Bolna AI Configuration
BOLNA_API_KEY=your_bolna_api_key_here
BOLNA_AGENT_ID=your_agent_id_here

# Server Configuration
PORT=3000

# Automation Settings
FEEDBACK_CALL_LIMIT=5
CALL_DELAY_MINUTES=5

# Firebase Configuration (optional — for production NoSQL storage)
# Download from: Firebase Console → Project Settings → Service Accounts → Generate New Private Key
FIREBASE_SERVICE_ACCOUNT_KEY_PATH=./firebase-service-account.json

# Google Sheets Configuration (optional — for team-visible spreadsheet)
# Requires a Google Cloud service account with Sheets API enabled
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./google-service-account.json
GOOGLE_SHEETS_ID=your_google_sheet_id_here
